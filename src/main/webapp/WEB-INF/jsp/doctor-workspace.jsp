<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>医生工作台</title><link rel="stylesheet" href="/clinic-ui.css"><script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script></head>
<body><header class="app-header"><div class="brand">医生工作台</div><nav class="nav"><a href="/doctor">医生端首页</a><a href="/">患者端</a><a href="/admin/login">管理端</a></nav></header>
<main class="container doctor-workspace"><aside><div class="page-title"><h3>候诊队列</h3></div><div class="form-row"><input id="queueDate" type="date" onchange="loadQueue()"><button class="btn secondary" onclick="loadQueue()">刷新</button></div><p class="muted" id="doctorProfile">正在加载医生信息...</p><div id="queue"></div></aside><section class="card"><h2 id="patientName">请选择患者</h2><p class="muted" id="patientMeta">左侧点击患者后，右侧展示预约信息并填写问诊结果。</p><input id="orderNo" type="hidden"><textarea id="symptoms" rows="4" style="width:100%" placeholder="主诉症状"></textarea><textarea id="diagnosis" rows="4" style="width:100%;margin-top:10px" placeholder="诊断结果"></textarea><textarea id="prescription" rows="5" style="width:100%;margin-top:10px" placeholder="处方明细，每行格式：药品名称|单次剂量|用法，例如：阿莫西林胶囊|0.5g|口服，一日三次"></textarea><button class="btn success" style="margin-top:12px" onclick="finishVisit()">完结问诊并生成病历/处方</button></section></main>
<script src="/doctor.js"></script></body></html>
