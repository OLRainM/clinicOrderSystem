<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>管理员系统</title><link rel="stylesheet" href="/clinic-ui.css"><script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js"></script><script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script></head>
<body><header class="app-header"><div class="brand">管理员系统</div><nav class="nav"><span class="role-badge">管理员</span><button class="btn secondary" onclick="clinicLogout()">退出</button></nav></header>
<div class="layout"><aside class="sidebar"><a class="side-link" href="/admin/dashboard">经营大屏</a><a class="side-link" href="/admin/schedule/manage">排班管理</a><a class="side-link" href="/admin/doctor/manage">医生管理</a><a class="side-link" href="/admin/department/manage">科室管理</a><a class="side-link" href="/admin/finance">财务流水</a></aside><main class="main">
<section id="panel-dashboard" class="admin-panel"><div class="page-title"><h2>经营数据大屏</h2><div><button class="btn secondary" onclick="loadStats(7)">近7天</button><button class="btn secondary" onclick="loadStats(30)">近30天</button><button class="btn" onclick="aggregateToday()">手动聚合今日</button></div></div><div class="stats-grid"><div class="card"><h3>科室就诊量</h3><div id="deptChart" class="chart"></div></div><div class="card"><h3>医生接诊率</h3><div id="doctorChart" class="chart"></div></div></div></section>
<section id="panel-schedule" class="admin-panel"><div class="page-title"><h2>排班管理</h2><div><button class="btn secondary" onclick="loadSchedules()">刷新</button><button class="btn success" onclick="openScheduleModal()">新增排班</button></div></div><div class="card schedule-filter"><label>开始日期<input id="filterStart" type="date"></label><label>结束日期<input id="filterEnd" type="date"></label><label>科室<select id="filterDept"></select></label><label>医生<select id="filterDoctor"></select></label><button class="btn" onclick="loadSchedules()">筛选</button></div><div id="scheduleList" class="schedule-list"></div></section>
<section id="panel-doctor" class="admin-panel"><div class="page-title"><h2>医生管理</h2><div><button class="btn success" onclick="openDoctorForm()">添加医生</button><button class="btn secondary" onclick="loadDoctors()">刷新</button></div></div><table class="table"><thead><tr><th>医生ID</th><th>姓名</th><th>职称</th><th>科室</th><th>操作</th></tr></thead><tbody id="doctorRows"><tr><td colspan="5">加载中...</td></tr></tbody></table></section>
<section id="panel-department" class="admin-panel"><div class="page-title"><h2>科室管理</h2><div><button class="btn success" onclick="openDepartmentForm()">添加科室</button><button class="btn secondary" onclick="loadDepartments()">刷新</button></div></div><table class="table"><thead><tr><th>科室ID</th><th>科室名称</th><th>操作</th></tr></thead><tbody id="departmentRows"><tr><td colspan="3">加载中...</td></tr></tbody></table></section>
<section id="panel-finance" class="admin-panel"><div class="page-title"><h2>财务流水</h2></div><div class="card"><p class="muted">当前展示经营统计入口，后续可接入支付流水明细表。</p><button class="btn secondary" onclick="showPanel('dashboard');loadStats(30)">查看近30天经营数据</button></div></section>
</main></div><script src="/role-nav.js"></script><script src="/admin.js"></script></body></html>
