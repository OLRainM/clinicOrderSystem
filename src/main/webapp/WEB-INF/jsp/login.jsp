<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8"><title>患者登录与注册</title><link rel="stylesheet" href="/clinic-ui.css"><script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script></head>
<body><header class="app-header"><div class="brand">患者账号中心</div><nav class="nav"><a href="/">首页</a><a href="/admin/login">管理员入口</a></nav></header>
<main class="container auth-page"><div class="grid auth-grid"><div class="card auth-card"><h2>患者登录</h2><p class="muted">仅用于预约挂号和查询过往预约。</p><input id="phone" placeholder="手机号" value="18800000001"><input id="password" type="password" placeholder="密码" value="Patient@123"><button class="btn" onclick="login()">登录</button></div><div class="card auth-card"><h2>患者注册</h2><input id="rPhone" placeholder="手机号"><input id="rPassword" type="password" placeholder="密码"><input id="rName" placeholder="真实姓名"><input id="rCard" placeholder="身份证号"><select id="rGender"><option value="1">男</option><option value="2">女</option></select><input id="rBirthday" type="date"><input id="rEmergency" placeholder="紧急联系人手机号"><button class="btn success" onclick="registerPatient()">注册并登录</button></div></div></main>
<script>async function login(){const res=await fetch('/api/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:phone.value,password:password.value})});const json=await res.json();if(!json.success){Swal.fire('登录失败',json.message,'error');return;}if(json.data.roleType!==1){Swal.fire('请使用患者账号','管理员请走管理员入口，医生请走医生工作台入口','warning');return;}location.href='/user/dashboard';}async function registerPatient(){const body={phone:rPhone.value,password:rPassword.value,realName:rName.value,idCardNo:rCard.value,gender:Number(rGender.value),emergencyContact:rEmergency.value};if(rBirthday.value)body.birthday=rBirthday.value;const res=await fetch('/api/auth/register/patient',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});const json=await res.json();if(!json.success){Swal.fire('注册失败',json.message,'error');return;}phone.value=rPhone.value;password.value=rPassword.value;await login();}</script>
</body></html>
